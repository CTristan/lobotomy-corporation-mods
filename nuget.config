<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="github" value="https://nuget.pkg.github.com/open-lobotomy/index.json" />
    <add key="local" value="/Users/chris/nuget-local" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="github">
      <package pattern="LobotomyCorporation.*" />
      <package pattern="OpenLobotomy.*" />
    </packageSource>
    <packageSource key="local">
      <package pattern="*" />
      <package pattern="LobotomyCorporation.*" />
      <package pattern="OpenLobotomy.*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
