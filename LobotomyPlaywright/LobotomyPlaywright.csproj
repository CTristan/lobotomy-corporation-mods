<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <OutputType>Exe</OutputType>
        <IsPackable>true</IsPackable>
        <PackAsTool>true</PackAsTool>
        <ToolCommandName>playwright</ToolCommandName>
        <PackageId>LobotomyCorporationMods.Playwright</PackageId>
        <Version>1.0.0</Version>
        <Description>CLI tool for LobotomyPlaywright game automation</Description>
        <Authors>CTristan</Authors>
        <PackageOutputPath>../nupkg</PackageOutputPath>
        <ProjectGuid>{A2B3C4D5-E6F7-8A9B-0C1D-2E3F4A5B6C7D}</ProjectGuid>
        <AnalysisLevel>latest-all</AnalysisLevel>
        <Deterministic>true</Deterministic>
        <EnableNETAnalyzers>true</EnableNETAnalyzers>
        <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
        <OutputPath>bin\</OutputPath>
        <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
        <Nullable>enable</Nullable>
        <LangVersion>latest</LangVersion>
        <NoWarn>$(NoWarn);CA1303;CA1515;CA1852;CA1034;CA1002;CA1031;CA1812;CA1869;CA1305;CA1304;CA1311;CA1310;CA1308;CA1861;CA1822;RCS1075</NoWarn>
    </PropertyGroup>
    <PropertyGroup Condition=" '$(Configuration)' == 'Debug' ">
        <DebugType>full</DebugType>
    </PropertyGroup>
    <PropertyGroup Condition=" '$(Configuration)' == 'Release' ">
        <CheckForOverflowUnderflow>true</CheckForOverflowUnderflow>
        <DebugType>none</DebugType>
        <WarningLevel>4</WarningLevel>
        <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    </PropertyGroup>
    <ItemGroup>
        <PackageReference Include="Roslynator.Analyzers" Version="1.4.0">
            <PrivateAssets>all</PrivateAssets>
            <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
        </PackageReference>
    </ItemGroup>
    <ItemGroup>
        <!-- Disable analyzers that conflict with testability -->
        <NoAnalyzer Include="CA1303"/>
        <NoAnalyzer Include="CA1515"/>
        <NoAnalyzer Include="CA1852"/>
        <NoAnalyzer Include="CA1034"/>
        <NoAnalyzer Include="CA1002"/>
        <NoAnalyzer Include="CA1031"/>
        <NoAnalyzer Include="CA1812"/>
    </ItemGroup>
</Project>
