root = true

# WHY: Prevent tabs across all file types (team convention)
[*]
indent_style = space

[*.{cs,csx}]
# WHY: Every source file must carry the SPDX license identifier (project policy)
file_header_template = SPDX-License-Identifier: MIT

# WHY: Enforce consistent naming and style rules across the codebase
dotnet_analyzer_diagnostic.category-Style.severity = error

# TODO: Remove temporary workaround when this bug is fixed: https://github.com/dotnet/format/issues/1623
dotnet_diagnostic.IDE0130.severity = suggestion

# WHY: Unity plugins use private methods for lifetime events
dotnet_diagnostic.IDE0051.severity = none
dotnet_diagnostic.IDE0052.severity = none

# WHY: All test projects share these conventions
[*.Test/**/*.cs]
# WHY: Tests should not have unused private members (opposite of earlier exclusion for Unity private methods)
dotnet_diagnostic.IDE0051.severity = error
dotnet_diagnostic.IDE0052.severity = error

# WHY: xUnit requires test classes to be public — dotnet format incorrectly converts them to internal
dotnet_diagnostic.CA1515.severity = none

# WHY: xUnit test methods use underscores in names (descriptive naming convention)
dotnet_diagnostic.CA1707.severity = none

# WHY: All Harmony_Patch classes share these conventions
[**/Harmony_Patch.cs]
# WHY: Harmony_Patch class names contain underscores (Basemod convention)
dotnet_diagnostic.CA1707.severity = none

# WHY: These are required for JsonUtility serialization
[**/JsonModels/**/*.cs]
# WHY: JsonUtility data classes require public lowercase fields and case-differing PascalCase accessors — Unity's serializer only works with public fields
dotnet_diagnostic.CA1708.severity = none

# WHY: Harmony patches use __ prefixed parameters (__instance, __result) that violate naming rules
[**/Patches/**.cs]
dotnet_diagnostic.IDE1006.severity = none
dotnet_diagnostic.CA1707.severity = none

# WHY: Harmony_Patch class names contain underscores (Basemod convention)
[**/Harmony_Patch.cs]
dotnet_diagnostic.CA1707.severity = none


# WHY: All test projects share these conventions
[**.Test/**.cs]
# WHY: xUnit requires test classes to be public — dotnet format incorrectly converts them to internal
dotnet_diagnostic.CA1515.severity = none
