root = true

# WHY: Prevent tabs across all file types (team convention)
[*]
indent_style = space

[*.{cs,csx}]
# BEGIN TEMPORARY BUILD WORKAROUND: Disable analyzers that cause build errors until the underlying issues are resolved

# WHY: Disable CS8604 (possible null reference) - nullable reference types are too strict for this codebase
dotnet_diagnostic.CS8604.severity = none
# WHY: Disable CS8620 (nullability differences) - nullable reference types are too strict for this codebase
dotnet_diagnostic.CS8620.severity = none
# WHY: Disable CS8625 (null literal to non-nullable) - nullable reference types are too strict for this codebase
dotnet_diagnostic.CS8625.severity = none
# WHY: Disable CS9113 (unread parameter) - sometimes parameters are intentionally unused
dotnet_diagnostic.CS9113.severity = none
# WHY: Disable CA1002 (use Collection<T> instead of List<T>) - List<T> is appropriate in many cases
dotnet_diagnostic.CA1002.severity = none
# WHY: Disable CA1031 (catch specific exception) - too strict for practical exception handling
dotnet_diagnostic.CA1031.severity = none
# WHY: Disable CA1034 (nested types) - nested types are sometimes appropriate
dotnet_diagnostic.CA1034.severity = none
# WHY: Disable CA1051 (visible instance fields) - required for JsonUtility serialization
dotnet_diagnostic.CA1051.severity = none
# WHY: Disable CA1062 (validate parameters) - too many false positives for parameter validation
dotnet_diagnostic.CA1062.severity = none
# WHY: Disable CA1303 (use resources for strings) - literal strings are fine for CLI tools
dotnet_diagnostic.CA1303.severity = none
# WHY: Disable CA1304/CA1305/CA1310/CA1311 (culture-specific string methods) - not relevant for CLI tools
dotnet_diagnostic.CA1304.severity = none
dotnet_diagnostic.CA1305.severity = none
dotnet_diagnostic.CA1310.severity = none
dotnet_diagnostic.CA1311.severity = none
# WHY: Disable CA1308 (use ToUpperInvariant) - ToLower is acceptable for this use case
dotnet_diagnostic.CA1308.severity = none
# WHY: Disable CA1515 (internal types) - public classes are fine for CLI tools
dotnet_diagnostic.CA1515.severity = none
# WHY: Disable CS1591 (missing XML comments) - XML comments are not required for internal tools
dotnet_diagnostic.CS1591.severity = none
# WHY: Disable CA1707 (remove underscores) - BepInEx plugins use underscored names
dotnet_diagnostic.CA1707.severity = none
# WHY: Disable CA1708 (names differ by case) - required for JsonUtility serialization (lowercase fields)
dotnet_diagnostic.CA1708.severity = none
# WHY: Disable CA1724 (type name conflicts with namespace) - naming conflict is acceptable
dotnet_diagnostic.CA1724.severity = none
# WHY: Disable CA1819 (properties return arrays) - arrays are needed for JsonUtility serialization
dotnet_diagnostic.CA1819.severity = none
# WHY: Disable CA1822 (mark static) - instance methods are sometimes preferred for future extensibility
dotnet_diagnostic.CA1822.severity = none
# WHY: Disable CA1852 (seal types) - not necessary for internal types
dotnet_diagnostic.CA1852.severity = none
# WHY: Disable CA1854 (prefer TryGetValue) - ContainsKey + indexer is sometimes clearer
dotnet_diagnostic.CA1854.severity = none
# WHY: Disable CA1859 (use concrete type) - interface parameters are sometimes preferred
dotnet_diagnostic.CA1859.severity = none
# WHY: Disable CA1861 (static readonly fields) - not critical for performance in this codebase
dotnet_diagnostic.CA1861.severity = none
# WHY: Disable CA1869 (cache JsonSerializerOptions) - creating new instances is acceptable for CLI tools
dotnet_diagnostic.CA1869.severity = none
# WHY: Disable CA2213 (dispose disposable) - test fixtures sometimes don't need explicit disposal
dotnet_diagnostic.CA2213.severity = none
# WHY: Disable CA2227 (read-only property) - setters are needed for JsonUtility deserialization
dotnet_diagnostic.CA2227.severity = none
# WHY: Disable CA2243 (GUID parsing) - BepInEx uses string GUIDs, not System.Guid
dotnet_diagnostic.CA2243.severity = none
# WHY: Disable IDE0008 (explicit type instead of var) - var is preferred in this codebase
dotnet_diagnostic.IDE0008.severity = none
# WHY: Disable IDE0038 (use pattern matching) - traditional comparison syntax is sometimes clearer
dotnet_diagnostic.IDE0038.severity = none
# WHY: Disable IDE0046/IDE0045 (simplify if statement) - conflicts with readable conditional logic
dotnet_diagnostic.IDE0045.severity = none
dotnet_diagnostic.IDE0046.severity = none
# WHY: Disable IDE0060 (unused parameter) - sometimes parameters are reserved for future use
dotnet_diagnostic.IDE0060.severity = none
# WHY: Disable IDE0073 (missing required header) - auto-generated files don't have headers
dotnet_diagnostic.IDE0073.severity = none
# WHY: Disable IDE0300/IDE0305 (simplify collection initialization) - not a priority
dotnet_diagnostic.IDE0300.severity = none
dotnet_diagnostic.IDE0305.severity = none
# WHY: Disable IDE1006 (naming rule violation) - game interface properties use camelCase to match game types
dotnet_diagnostic.IDE1006.severity = none
# WHY: Disable RCS1075 (avoid empty catch clause) - empty catch is sometimes intentional
dotnet_diagnostic.RCS1075.severity = none

# END TEMPORARY BUILD WORKAROUND

# WHY: Every source file must carry the SPDX license identifier (project policy)
file_header_template = SPDX-License-Identifier: MIT

# WHY: Enforce consistent naming and style rules across the codebase
dotnet_analyzer_diagnostic.category-Style.severity = error

# TODO: Remove temporary workaround when this bug is fixed: https://github.com/dotnet/format/issues/1623
dotnet_diagnostic.IDE0130.severity = suggestion

# WHY: Unity plugins use private methods for lifetime events
dotnet_diagnostic.IDE0051.severity = none
dotnet_diagnostic.IDE0052.severity = none

# TODO: Remove temporary workaround when this bug is fixed: https://github.com/dotnet/format/issues/1623
dotnet_diagnostic.IDE0130.severity = suggestion

# WHY: All test projects share these conventions
[*.Test/**/*.cs]
# WHY: Tests should not have unused private members (opposite of earlier exclusion for Unity private methods)
dotnet_diagnostic.IDE0051.severity = error
dotnet_diagnostic.IDE0052.severity = error

# WHY: xUnit requires test classes to be public — dotnet format incorrectly converts them to internal
dotnet_diagnostic.CA1515.severity = none

# WHY: xUnit test methods use underscores in names (descriptive naming convention)
dotnet_diagnostic.CA1707.severity = none

# WHY: All Harmony_Patch classes share these conventions
[**/Harmony_Patch.cs]
# WHY: Harmony_Patch class names contain underscores (Basemod convention)
dotnet_diagnostic.CA1707.severity = none

# WHY: These are required for JsonUtility serialization
[**/JsonModels/**/*.cs]
# WHY: JsonUtility data classes require public lowercase fields and case-differing PascalCase accessors — Unity's serializer only works with public fields
dotnet_diagnostic.CA1708.severity = none

# WHY: Harmony patches use __ prefixed parameters (__instance, __result) that violate naming rules
[**/Patches/**.cs]
dotnet_diagnostic.IDE1006.severity = none
dotnet_diagnostic.CA1707.severity = none

# WHY: Harmony_Patch class names contain underscores (Basemod convention)
[**/Harmony_Patch.cs]
dotnet_diagnostic.CA1707.severity = none

# WHY: All test projects share these conventions
[**.Test/**.cs]
# WHY: xUnit requires test classes to be public — dotnet format incorrectly converts them to internal
dotnet_diagnostic.CA1515.severity = none
