root = true

# WHY: Prevent tabs across all file types (team convention)
[*]
indent_style = space

[*.{cs,csx}]
# WHY: Set our helper method as a null check validator to satisfy CA1062 without needing to add redundant null checks or suppressions
dotnet_code_quality.CA1062.null_check_validation_methods = ThrowIfNull

# WHY: Treat all analyzer warnings as errors to maintain code quality standards
dotnet_analyzer_diagnostic.severity = error

# BEGIN TEMPORARY BUILD WORKAROUND: Disable analyzers that cause build errors until the underlying issues are resolved



# Microsoft analyzers (CA*)
# WHY: Disable CA1303 (use resources for strings) - literal strings are fine for CLI tools
dotnet_diagnostic.CA1303.severity = none
# WHY: Disable CA1304/CA1305/CA1310/CA1311 (culture-specific string methods) - not relevant for CLI tools
dotnet_diagnostic.CA1304.severity = none
dotnet_diagnostic.CA1305.severity = none
dotnet_diagnostic.CA1310.severity = none
dotnet_diagnostic.CA1311.severity = none
# WHY: Disable CA1308 (use ToUpperInvariant) - ToLower is acceptable for this use case
dotnet_diagnostic.CA1308.severity = none
# WHY: Disable CA1515 (internal types) - public classes are fine for CLI tools
dotnet_diagnostic.CA1515.severity = none
# WHY: Disable CS1591 (missing XML comments) - XML comments are not required for internal tools
dotnet_diagnostic.CS1591.severity = none
# WHY: Disable CA1707 (remove underscores) - BepInEx plugins use underscored names
dotnet_diagnostic.CA1707.severity = none
# WHY: Disable CA1708 (names differ by case) - required for JsonUtility serialization (lowercase fields)
dotnet_diagnostic.CA1708.severity = none
# WHY: Disable CA1724 (type name conflicts with namespace) - naming conflict is acceptable
dotnet_diagnostic.CA1724.severity = none
# WHY: Disable CA1819 (properties return arrays) - arrays are needed for JsonUtility serialization
dotnet_diagnostic.CA1819.severity = none
# WHY: Disable CA1822 (mark static) - instance methods are sometimes preferred for future extensibility
dotnet_diagnostic.CA1822.severity = none
# WHY: Disable CA1852 (seal types) - not necessary for internal types
dotnet_diagnostic.CA1852.severity = none
# WHY: Disable CA1854 (prefer TryGetValue) - ContainsKey + indexer is sometimes clearer
dotnet_diagnostic.CA1854.severity = none
# WHY: Disable CA1859 (use concrete type) - interface parameters are sometimes preferred
dotnet_diagnostic.CA1859.severity = none
# WHY: Disable CA1861 (static readonly fields) - not critical for performance in this codebase
dotnet_diagnostic.CA1861.severity = none
# WHY: Disable CA1869 (cache JsonSerializerOptions) - creating new instances is acceptable for CLI tools
dotnet_diagnostic.CA1869.severity = none
# WHY: Disable CA2213 (dispose disposable) - test fixtures sometimes don't need explicit disposal
dotnet_diagnostic.CA2213.severity = none
# WHY: Disable CA2227 (read-only property) - setters are needed for JsonUtility deserialization
dotnet_diagnostic.CA2227.severity = none
# WHY: Disable CA2243 (GUID parsing) - BepInEx uses string GUIDs, not System.Guid
dotnet_diagnostic.CA2243.severity = none

# Microsoft code style analyzers (IDE*)
# WHY: Disable IDE0008 (explicit type instead of var) - var is preferred in this codebase
dotnet_diagnostic.IDE0008.severity = none
# WHY: Disable IDE0038 (use pattern matching) - traditional comparison syntax is sometimes clearer
dotnet_diagnostic.IDE0038.severity = none
# WHY: Disable IDE0046/IDE0045 (simplify if statement) - conflicts with readable conditional logic
dotnet_diagnostic.IDE0045.severity = none
dotnet_diagnostic.IDE0046.severity = none
# WHY: Disable IDE0060 (unused parameter) - sometimes parameters are reserved for future use
dotnet_diagnostic.IDE0060.severity = none
# WHY: Disable IDE0300/IDE0305 (simplify collection initialization) - not a priority
dotnet_diagnostic.IDE0300.severity = none
dotnet_diagnostic.IDE0305.severity = none
# WHY: Disable IDE1006 (naming rule violation) - game interface properties use camelCase to match game types
dotnet_diagnostic.IDE1006.severity = none

# Roslynator analyzers (RCS*)
# WHY: Disable RCS1006 (merge else with nested if) - current code style is readable
dotnet_diagnostic.RCS1006.severity = none
# WHY: Disable RCS1015 (use nameof) - not a priority
dotnet_diagnostic.RCS1015.severity = none
# WHY: Disable RCS1037 (remove trailing whitespace) - not a priority
dotnet_diagnostic.RCS1037.severity = none
# WHY: Disable RCS1061 (merge if with nested if) - current code style is readable
dotnet_diagnostic.RCS1061.severity = none
# WHY: Disable RCS1069 (remove unnecessary case label) - not a priority
dotnet_diagnostic.RCS1069.severity = none
# WHY: Disable RCS1070 (remove redundant default switch) - not a priority
dotnet_diagnostic.RCS1070.severity = none
# WHY: Disable RCS1073 (convert if to return) - not a priority
dotnet_diagnostic.RCS1073.severity = none
# WHY: Disable RCS1075 (avoid empty catch clause) - empty catch is sometimes intentional
dotnet_diagnostic.RCS1075.severity = none
# WHY: Disable RCS1118 (mark local variable as const) - not a priority
dotnet_diagnostic.RCS1118.severity = none
# WHY: Disable RCS1124 (inline local variable) - not a priority
dotnet_diagnostic.RCS1124.severity = none
# WHY: Disable RCS1134 (remove redundant statement) - not a priority
dotnet_diagnostic.RCS1134.severity = none
# WHY: Disable RCS1136 (merge switch sections) - not a priority
dotnet_diagnostic.RCS1136.severity = none
# WHY: Disable RCS1140 (add exception to documentation) - not a priority
dotnet_diagnostic.RCS1140.severity = none
# WHY: Disable RCS1141 (add param element to documentation) - not a priority
dotnet_diagnostic.RCS1141.severity = none
# WHY: Disable RCS1146 (use conditional access) - not a priority
dotnet_diagnostic.RCS1146.severity = none
# WHY: Disable RCS1154 (sort members) - not a priority
dotnet_diagnostic.RCS1154.severity = none
# WHY: Disable RCS1161 (enum should declare explicit values) - not a priority
dotnet_diagnostic.RCS1161.severity = none
# WHY: Disable RCS1163 (unused parameter) - not a priority
dotnet_diagnostic.RCS1163.severity = none
# WHY: Disable RCS1170 (use read-only auto property) - not a priority
dotnet_diagnostic.RCS1170.severity = none
# WHY: Disable RCS1175 (unused this parameter) - not a priority
dotnet_diagnostic.RCS1175.severity = none
# WHY: Disable RCS1181 (convert comment to documentation) - not a priority
dotnet_diagnostic.RCS1181.severity = none
# WHY: Disable RCS1186 (use Regex instance) - not a priority
dotnet_diagnostic.RCS1186.severity = none
# WHY: Disable RCS1189 (add region name to endregion) - not a priority
dotnet_diagnostic.RCS1189.severity = none
# WHY: Disable RCS1206 (use conditional access) - not a priority
dotnet_diagnostic.RCS1206.severity = none
# WHY: Disable RCS1211 (remove unnecessary else clause) - not a priority
dotnet_diagnostic.RCS1211.severity = none
# WHY: Disable RCS1214 (unnecessary interpolated string) - not a priority
dotnet_diagnostic.RCS1214.severity = none
# WHY: Disable RCS1218 (simplify code branching) - not a priority
dotnet_diagnostic.RCS1218.severity = none
# WHY: Disable RCS1217 (convert interpolated string to concatenation) - not a priority
dotnet_diagnostic.RCS1217.severity = none
# WHY: Disable RCS1021 (use expression-bodied lambda) - not a priority
dotnet_diagnostic.RCS1021.severity = none
# WHY: Disable RCS1089 (use ++ operator) - not a priority
dotnet_diagnostic.RCS1089.severity = none
# WHY: Disable RCS1142 (addtypeparam element to documentation) - not a priority
dotnet_diagnostic.RCS1142.severity = none
# WHY: Disable RCS1212 (remove redundant assignment) - not a priority
dotnet_diagnostic.RCS1212.severity = none
# WHY: Disable RCS1257 (use enum field explicitly) - not a priority
dotnet_diagnostic.RCS1257.severity = none
# WHY: Disable RCS1220 (use pattern matching) - not a priority
dotnet_diagnostic.RCS1220.severity = none
# WHY: Disable RCS1226 (add paragraph to documentation) - not a priority
dotnet_diagnostic.RCS1226.severity = none
# WHY: Disable RCS1228 (unused param/returns element in documentation) - not a priority
dotnet_diagnostic.RCS1228.severity = none
# WHY: Disable RCS1238 (avoid nested ternary) - not a priority
dotnet_diagnostic.RCS1238.severity = none
# WHY: Disable RCS1239 (use for instead of while) - not a priority
dotnet_diagnostic.RCS1239.severity = none
# WHY: Disable RCS1266 (use raw string literal) - not a priority
dotnet_diagnostic.RCS1266.severity = none
# WHY: Disable RCS1267 (use string interpolation) - not a priority
dotnet_diagnostic.RCS1267.severity = none

# System analyzers (SYSLIB*)
# WHY: Disable SYSLIB1045 (GeneratedRegexAttribute) - not a priority
dotnet_diagnostic.SYSLIB1045.severity = none

# Unity analyzers (UNT*)
# WHY: Disable UNT0007 (null coalescing for Unity objects) - not a priority
dotnet_diagnostic.UNT0007.severity = none
# WHY: Disable UNT0008 (null propagation for Unity objects) - not a priority
dotnet_diagnostic.UNT0008.severity = none

# xUnit analyzers
# WHY: Disable xUnit1042 (use TheoryData instead of object array) - not a priority
dotnet_diagnostic.xUnit1042.severity = none

# END TEMPORARY BUILD WORKAROUND

# WHY: Every source file must carry the SPDX license identifier (project policy)
file_header_template = SPDX-License-Identifier: MIT

# WHY: Enforce consistent naming and style rules across the codebase
dotnet_analyzer_diagnostic.category-Style.severity = error

# TODO: Remove temporary workaround when this bug is fixed: https://github.com/dotnet/format/issues/1623
dotnet_diagnostic.IDE0130.severity = suggestion

# WHY: Unity plugins use private methods for lifetime events
dotnet_diagnostic.IDE0051.severity = none
dotnet_diagnostic.IDE0052.severity = none
dotnet_diagnostic.RCS1213.severity = none

# WHY: MyPluginInfo is autogenerated by BepInEx and must follow their conventions
[**/MyPluginInfo.cs]
# WHY: Can't add the required header to autogenerated files
dotnet_diagnostic.IDE0073.severity = none

# WHY: All test projects share these conventions
[{*.Test,**/*.Test}/{*.cs,**/*.cs}]
# WHY: Tests should not have unused private members (opposite of earlier exclusion for Unity private methods)
dotnet_diagnostic.IDE0051.severity = error
dotnet_diagnostic.IDE0052.severity = error

# WHY: xUnit requires test classes to be public — dotnet format incorrectly converts them to internal
dotnet_diagnostic.CA1515.severity = none

# WHY: xUnit test methods use underscores in names (descriptive naming convention)
dotnet_diagnostic.CA1707.severity = none

dotnet_diagnostic.IDE0058.severity = none

# WHY: All Harmony_Patch classes share these conventions
[{Harmony_Patch.cs,**/Harmony_Patch.cs}]
# WHY: Harmony_Patch class names contain underscores (Basemod convention)
dotnet_diagnostic.CA1707.severity = none

# WHY: These are required for JsonUtility serialization
[{JsonModels,**/JsonModels}/{*.cs,**/*.cs}]
# WHY: JsonUtility does not support collections other than arrays and List<T>
dotnet_diagnostic.CA1002.severity = none

# WHY: JsonUtility only serializes fields, not properties — public fields are required
dotnet_diagnostic.CA1051.severity = none

# WHY: JsonUtility data classes require public lowercase fields and case-differing PascalCase accessors — Unity's serializer only works with public fields
dotnet_diagnostic.CA1708.severity = none

# WHY: Harmony patches use __ prefixed parameters (__instance, __result) that violate naming rules
[{Patches,**/Patches}/{*.cs,**/*.cs}]
dotnet_diagnostic.IDE1006.severity = none
dotnet_diagnostic.CA1707.severity = none

