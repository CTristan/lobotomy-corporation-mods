<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <OutputType>Exe</OutputType>
        <IsPackable>true</IsPackable>
        <PackAsTool>true</PackAsTool>
        <ToolCommandName>ci</ToolCommandName>
        <PackageId>LobotomyCorporationMods.CI</PackageId>
        <Version>1.0.0</Version>
        <Description>CI tool for Lobotomy Corporation mods</Description>
        <Authors>CTristan</Authors>
        <PackageOutputPath>../nupkg</PackageOutputPath>
        <ProjectGuid>{C3D4E5F6-7A8B-9C0D-1E2F-3A4B5C6D7E8F}</ProjectGuid>
        <AnalysisLevel>latest-all</AnalysisLevel>
        <Deterministic>true</Deterministic>
        <EnableNETAnalyzers>true</EnableNETAnalyzers>
        <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
        <OutputPath>bin\</OutputPath>
        <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
        <Nullable>enable</Nullable>
    </PropertyGroup>
    <PropertyGroup Condition=" '$(Configuration)' == 'Debug' ">
        <DebugType>full</DebugType>
    </PropertyGroup>
    <PropertyGroup Condition=" '$(Configuration)' == 'Release' ">
        <CheckForOverflowUnderflow>true</CheckForOverflowUnderflow>
        <DebugType>none</DebugType>
        <WarningLevel>4</WarningLevel>
        <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    </PropertyGroup>
    <ItemGroup>
        <PackageReference Include="Roslynator.Analyzers" Version="1.4.0">
            <PrivateAssets>all</PrivateAssets>
            <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
        </PackageReference>
    </ItemGroup>
    <ItemGroup>
        <!-- Disable analyzers that conflict with testability -->
        <NoAnalyzer Include="CA1303"/>
        <NoAnalyzer Include="CA1515"/>
        <NoAnalyzer Include="CA1852"/>
        <NoAnalyzer Include="CA1034"/>
        <NoAnalyzer Include="CA1002"/>
    </ItemGroup>
</Project>
