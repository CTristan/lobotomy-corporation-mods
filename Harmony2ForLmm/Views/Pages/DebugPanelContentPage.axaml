<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="clr-namespace:LiveMarkdown.Avalonia;assembly=LiveMarkdown.Avalonia"
             x:Class="Harmony2ForLmm.Views.Pages.DebugPanelContentPage">

  <DockPanel>

    <!-- Install button and status -->
    <StackPanel DockPanel.Dock="Bottom"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="8"
                Margin="0,16,0,0">
      <TextBlock x:Name="StatusText"
                 VerticalAlignment="Center"
                 FontSize="13"
                 Margin="0,0,16,0" />
      <Button x:Name="InstallButton"
              Classes="accent"
              Padding="20,8"
              Click="InstallButton_Click" />
    </StackPanel>

    <!-- Loading / content area fills remaining space -->
    <Grid>
      <!-- Loading indicator (visible until markdown finishes rendering) -->
      <StackPanel x:Name="LoadingPanel"
                  VerticalAlignment="Center"
                  HorizontalAlignment="Center"
                  Spacing="12">
        <ProgressBar IsIndeterminate="True"
                     Width="300"
                     Height="20" />
        <TextBlock Text="Loading..."
                   HorizontalAlignment="Center"
                   Foreground="{DynamicResource SystemBaseMediumColor}"
                   FontSize="14" />
      </StackPanel>

      <!-- Scrollable markdown content -->
      <ScrollViewer x:Name="ContentScrollViewer"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto"
                    IsVisible="False">
        <md:MarkdownRenderer x:Name="MarkdownViewer" />
      </ScrollViewer>
    </Grid>

  </DockPanel>
</UserControl>
