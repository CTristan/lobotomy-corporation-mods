<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="clr-namespace:LiveMarkdown.Avalonia;assembly=LiveMarkdown.Avalonia"
             x:Class="Harmony2ForLmm.Views.Pages.GuideContentPage">

  <DockPanel>

    <!-- Optional action buttons above content -->
    <StackPanel DockPanel.Dock="Bottom"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="8"
                Margin="0,16,0,0">
      <TextBlock x:Name="DocStatusMessage"
                 VerticalAlignment="Center"
                 Foreground="{DynamicResource SystemBaseMediumColor}"
                 FontSize="13"
                 IsVisible="False" />
      <Button x:Name="OpenDocButton"
              Content="Open Document"
              Classes="secondary"
              Padding="20,8"
              IsVisible="False"
              Click="OpenDocButton_Click" />
      <Button x:Name="SampleProjectButton"
              Content="View Sample Project"
              Classes="secondary"
              Padding="20,8"
              IsVisible="False"
              Click="SampleProjectButton_Click" />
      <Button x:Name="OpenFolderButton"
              Content="Open in File Manager"
              Classes="secondary"
              Padding="20,8"
              IsVisible="False"
              Click="OpenFolderButton_Click" />
    </StackPanel>

    <!-- Loading / content area fills remaining space -->
    <Grid>
      <!-- Loading indicator (visible until markdown finishes rendering) -->
      <StackPanel x:Name="LoadingPanel"
                  VerticalAlignment="Center"
                  HorizontalAlignment="Center"
                  Spacing="12">
        <ProgressBar IsIndeterminate="True"
                     Width="300"
                     Height="20" />
        <TextBlock Text="Loading..."
                   HorizontalAlignment="Center"
                   Foreground="{DynamicResource SystemBaseMediumColor}"
                   FontSize="14" />
      </StackPanel>

      <!-- Scrollable markdown content -->
      <ScrollViewer x:Name="ContentScrollViewer"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto"
                    IsVisible="False">
        <md:MarkdownRenderer x:Name="MarkdownViewer" />
      </ScrollViewer>
    </Grid>

  </DockPanel>
</UserControl>
