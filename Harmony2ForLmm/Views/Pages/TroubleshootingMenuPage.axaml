<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Harmony2ForLmm.Views.Pages.TroubleshootingMenuPage">

  <StackPanel VerticalAlignment="Center" Spacing="16">
    <TextBlock Text="Troubleshooting"
               Classes="header"
               HorizontalAlignment="Center" />
    <Button Content="DebugPanel"
            Classes="accent"
            HorizontalAlignment="Stretch"
            HorizontalContentAlignment="Center"
            Click="DebugPanelButton_Click" />
    <Button Content="User's Guide"
            Classes="accent"
            HorizontalAlignment="Stretch"
            HorizontalContentAlignment="Center"
            Click="UsersGuideButton_Click" />
  </StackPanel>

</UserControl>
