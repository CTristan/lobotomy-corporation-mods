<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Harmony2ForLmm.ViewModels"
        xmlns:iface="using:Harmony2ForLmm.Interfaces"
        x:Class="Harmony2ForLmm.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        x:CompileBindings="True"
        Title="{Binding WindowTitle}"
        Width="700"
        Height="800"
        MinWidth="600"
        MinHeight="650"
        WindowStartupLocation="CenterScreen">

  <Design.DataContext>
    <vm:MainWindowViewModel />
  </Design.DataContext>

  <DockPanel Margin="24">

    <!-- Title -->
    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,16">
      <TextBlock Text="{Binding WindowTitle}"
                 FontSize="28"
                 FontWeight="Bold"
                 Foreground="#d4a017"
                 HorizontalAlignment="Center" />
      <TextBlock Text="A compatibility layer that lets Harmony 2 mods run in Lobotomy Corporation"
                 FontSize="13"
                 Foreground="#808080"
                 HorizontalAlignment="Center"
                 Margin="0,4,0,0" />
    </StackPanel>

    <Separator DockPanel.Dock="Top" />

    <!-- Game Path Section -->
    <Border DockPanel.Dock="Top" Classes="panel" Margin="0,0,0,16">
      <StackPanel Spacing="8">
        <TextBlock Text="Game Directory" Classes="header" />

        <DockPanel>
          <Button DockPanel.Dock="Right"
                  Content="Browse..."
                  Classes="secondary"
                  Margin="8,0,0,0"
                  IsEnabled="{Binding IsPathEditable}"
                  Click="BrowseButton_Click" />
          <Button DockPanel.Dock="Right"
                  Content="Auto-Detect"
                  Classes="secondary"
                  Margin="8,0,0,0"
                  Command="{Binding AutoDetectCommand}" />
          <TextBox Text="{Binding GamePath}"
                   IsEnabled="{Binding IsPathEditable}"
                   Watermark="Enter or browse for Lobotomy Corporation installation path..." />
        </DockPanel>

        <!-- Validation -->
        <TextBlock Text="{Binding ValidationMessage}"
                   Classes.valid="{Binding IsPathValid}"
                   Classes.invalid="{Binding !IsPathValid}"
                   FontSize="12" />

        <!-- Installation status is shown in the actions panel below -->
      </StackPanel>
    </Border>

    <!-- Close button at bottom -->
    <Border DockPanel.Dock="Bottom" Margin="0,16,0,0">
      <Button Content="Close"
              Classes="secondary"
              Command="{Binding CloseCommand}"
              HorizontalAlignment="Right"
              Padding="20,8" />
    </Border>

    <!-- Status bar (hidden when action completed — message moves to actions panel) -->
    <Border DockPanel.Dock="Bottom"
            Margin="0,16,0,0"
            IsVisible="{Binding !IsActionCompleted}">
      <TextBlock Text="{Binding StatusMessage}"
                 Classes="status"
                 Classes.invalid="{Binding IsLastActionFailed}"
                 TextWrapping="Wrap" />
    </Border>

    <!-- Action Buttons (scrollable when content is tall) -->
    <ScrollViewer DockPanel.Dock="Top"
                  HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
      <Border Classes="panel">
        <StackPanel Spacing="16">
          <TextBlock Text="Actions" Classes="header" />

          <!-- Completion confirmation: shown after action completes -->
          <Border Classes="success"
                  IsVisible="{Binding IsActionCompleted}">
            <TextBlock Text="{Binding StatusMessage}"
                       TextWrapping="Wrap"
                       FontWeight="Bold"
                       FontSize="16"
                       Foreground="#17d440"
                       HorizontalAlignment="Center" />
          </Border>

          <!-- Status details: hidden after successful action completion -->
          <StackPanel Spacing="16" IsVisible="{Binding !IsActionCompleted}">

            <!-- Version info -->
            <TextBlock Text="{Binding VersionInfoText}"
                       FontSize="12"
                       Foreground="#808080"
                       HorizontalAlignment="Center"
                       IsVisible="{Binding VersionInfoText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

            <!-- Version warning (Newer state) -->
            <Border Classes="warning"
                    IsVisible="{Binding ShowVersionWarning}">
              <TextBlock Text="Warning: A newer version is currently installed. Proceeding will downgrade."
                         TextWrapping="Wrap"
                         FontWeight="Bold"
                         Foreground="#d44017" />
            </Border>

            <!-- Missing files list (Corrupted state) -->
            <Border Classes="warning"
                    IsVisible="{Binding MissingFiles.Count}">
              <StackPanel Spacing="4">
                <TextBlock Text="Installation is corrupted — missing files detected:"
                           FontWeight="Bold"
                           Foreground="#d44017" />
                <ItemsControl ItemsSource="{Binding MissingFiles}" Margin="8,4,0,0">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                      <TextBlock Text="{Binding}"
                                 Foreground="#c0a0a0"
                                 FontSize="12" />
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>

            <!-- Flagged mods warning -->
            <Border Classes="warning"
                    IsVisible="{Binding FlaggedMods.Count}">
              <StackPanel Spacing="4">
                <TextBlock Text="Warning: Dependent mods detected"
                           FontWeight="Bold"
                           Foreground="#d44017" />
                <TextBlock Text="The following BaseMods reference BepInEx or Harmony 2+ and will stop working if you uninstall:"
                           TextWrapping="Wrap"
                           FontSize="12"
                           Foreground="#c0a0a0" />
                <ItemsControl ItemsSource="{Binding FlaggedMods}" Margin="8,4,0,0">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="iface:FlaggedMod">
                      <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{Binding FileName}"
                                   Foreground="#e0e0e0"
                                   FontSize="12" />
                        <TextBlock Text="{Binding ReferencedAssembly}"
                                   Foreground="#808080"
                                   FontSize="11" />
                      </StackPanel>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>

            <!-- DebugPanel removal checkbox -->
            <CheckBox Content="Also remove DebugPanel"
                      IsChecked="{Binding RemoveDebugPanel}"
                      IsVisible="{Binding ShowDebugPanelCheckbox}"
                      Foreground="#c0a0a0"
                      FontSize="13" />

            <!-- Progress indicator -->
            <ProgressBar IsIndeterminate="True"
                         IsVisible="{Binding IsWorking}" />

          </StackPanel>

          <!-- Action buttons: two rows of two -->
          <StackPanel Spacing="8">
            <Grid ColumnDefinitions="*,16,*">
              <Button Grid.Column="0"
                      Content="{Binding PrimaryActionLabel}"
                      Classes="accent"
                      Command="{Binding PrimaryActionCommand}"
                      IsVisible="{Binding ShowPrimaryAction}"
                      HorizontalAlignment="Stretch" />
              <Button Grid.Column="2"
                      Content="Uninstall"
                      Classes="danger"
                      Command="{Binding UninstallCommand}"
                      IsVisible="{Binding ShowUninstallAction}"
                      HorizontalAlignment="Stretch" />
            </Grid>
            <Grid ColumnDefinitions="*,16,*">
              <Button Grid.Column="0"
                      Content="Guides"
                      Classes="secondary"
                      Command="{Binding GuidesCommand}"
                      Padding="20,12"
                      FontSize="16"
                      HorizontalContentAlignment="Center"
                      HorizontalAlignment="Stretch" />
              <Button Grid.Column="2"
                      Content="Troubleshooting"
                      Classes="secondary"
                      Command="{Binding TroubleshootingCommand}"
                      Padding="20,12"
                      FontSize="16"
                      HorizontalContentAlignment="Center"
                      HorizontalAlignment="Stretch" />
            </Grid>
          </StackPanel>

        </StackPanel>
      </Border>
    </ScrollViewer>

    <!-- Result details (fills remaining space) -->
    <TextBox Text="{Binding ResultDetails}"
             Classes="log"
             MinHeight="100"
             Margin="0,16,0,0"
             IsVisible="{Binding ResultDetails, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

  </DockPanel>
</Window>
