<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Harmony2ForLmm.Views.GuidesWindow"
        Width="400"
        Height="250"
        MinWidth="350"
        MinHeight="200"
        WindowStartupLocation="CenterOwner"
        Title="Guides">

  <DockPanel Margin="24">

    <!-- Bottom buttons -->
    <StackPanel DockPanel.Dock="Bottom"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Margin="0,16,0,0">
      <Button Content="Close"
              Classes="secondary"
              Padding="20,8"
              Click="CloseButton_Click" />
    </StackPanel>

    <!-- Guide buttons -->
    <StackPanel VerticalAlignment="Center" Spacing="16">
      <TextBlock Text="Guides"
                 Classes="header"
                 HorizontalAlignment="Center" />
      <Button Content="User's Guide"
              Classes="accent"
              HorizontalAlignment="Stretch"
              HorizontalContentAlignment="Center"
              Click="UsersGuideButton_Click" />
      <Button Content="Modder's Guide"
              Classes="accent"
              HorizontalAlignment="Stretch"
              HorizontalContentAlignment="Center"
              Click="ModdersGuideButton_Click" />
    </StackPanel>

  </DockPanel>
</Window>
