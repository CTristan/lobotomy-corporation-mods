<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:md="clr-namespace:LiveMarkdown.Avalonia;assembly=LiveMarkdown.Avalonia"
        x:Class="Harmony2ForLmm.Views.GuideWindow"
        Width="800"
        Height="700"
        MinWidth="600"
        MinHeight="400"
        WindowStartupLocation="CenterOwner">

  <DockPanel Margin="24">

    <!-- Bottom buttons (docked first so they're always visible) -->
    <StackPanel DockPanel.Dock="Bottom"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="8"
                Margin="0,16,0,0">
      <Button x:Name="SampleProjectButton"
              Content="View Sample Project"
              Classes="secondary"
              Padding="20,8"
              IsVisible="False"
              Click="SampleProjectButton_Click" />
      <Button x:Name="OpenFolderButton"
              Content="Open in File Manager"
              Classes="secondary"
              Padding="20,8"
              IsVisible="False"
              Click="OpenFolderButton_Click" />
      <Button Content="Close"
              Classes="secondary"
              Padding="20,8"
              Click="CloseButton_Click" />
    </StackPanel>

    <!-- Scrollable markdown content fills remaining space -->
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
      <md:MarkdownRenderer x:Name="MarkdownViewer" />
    </ScrollViewer>

  </DockPanel>
</Window>
