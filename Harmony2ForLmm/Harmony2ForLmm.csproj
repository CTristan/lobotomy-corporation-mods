<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <OutputType>WinExe</OutputType>
    <AssemblyVersion>0.0.1.0</AssemblyVersion>
    <Nullable>enable</Nullable>
    <ProjectGuid>{E5F6A7B8-1C2D-3E4F-5A6B-7C8D9E0F1A2B}</ProjectGuid>
    <!-- IL2026: COM interop trim warning from runtime; IL2104: Mono.Cecil trim warnings (third-party) -->
    <NoWarn>$(NoWarn);IL2026;IL2104</NoWarn>
    <BuiltInComInteropSupport>true</BuiltInComInteropSupport>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <DefaultItemExcludes>$(DefaultItemExcludes);DemoMod\**</DefaultItemExcludes>
  </PropertyGroup>
  <!-- Zip DemoMod source for distribution (excludes build artifacts).
       ZipDirectory doesn't support excludes, so we copy source files to a staging
       directory first and zip that. -->
  <Target Name="ZipDemoMod" BeforeTargets="Build"
          Inputs="DemoMod\**\*.cs;DemoMod\**\*.csproj;DemoMod\**\*.md"
          Outputs="Resources\DemoMod.zip">
    <ItemGroup>
      <DemoModFiles Include="DemoMod\**\*"
                    Exclude="DemoMod\**\obj\**;DemoMod\**\bin\**;DemoMod\**\.DS_Store" />
    </ItemGroup>
    <RemoveDir Directories="$(IntermediateOutputPath)DemoModStaging" />
    <Copy SourceFiles="@(DemoModFiles)"
          DestinationFiles="@(DemoModFiles->'$(IntermediateOutputPath)DemoModStaging\DemoMod\%(RecursiveDir)%(Filename)%(Extension)')" />
    <MakeDir Directories="Resources" Condition="!Exists('Resources')" />
    <Delete Files="Resources\DemoMod.zip" Condition="Exists('Resources\DemoMod.zip')" />
    <ZipDirectory SourceDirectory="$(IntermediateOutputPath)DemoModStaging"
                  DestinationFile="Resources\DemoMod.zip"
                  Overwrite="true" />
    <RemoveDir Directories="$(IntermediateOutputPath)DemoModStaging" />
  </Target>
  <!-- Zip BepInEx distribution for embedding (excludes junk files).
       Same staging approach as ZipDemoMod. -->
  <Target Name="ZipBepInEx" BeforeTargets="BeforeBuild" DependsOnTargets="ZipDemoMod"
          Inputs="Resources/bepinex/**/*"
          Outputs="$(IntermediateOutputPath)bepinex.zip">
    <ItemGroup>
      <BepInExFiles Include="Resources/bepinex/**/*"
                    Exclude="Resources/bepinex/**/.DS_Store;Resources/bepinex/**/*.md;Resources/bepinex/**/changelog*;Resources/bepinex/**/.gitignore" />
    </ItemGroup>
    <RemoveDir Directories="$(IntermediateOutputPath)BepInExStaging" />
    <Copy SourceFiles="@(BepInExFiles)"
          DestinationFiles="@(BepInExFiles->'$(IntermediateOutputPath)BepInExStaging/%(RecursiveDir)%(Filename)%(Extension)')" />
    <Delete Files="$(IntermediateOutputPath)bepinex.zip" Condition="Exists('$(IntermediateOutputPath)bepinex.zip')" />
    <ZipDirectory SourceDirectory="$(IntermediateOutputPath)BepInExStaging"
                  DestinationFile="$(IntermediateOutputPath)bepinex.zip"
                  Overwrite="true" />
    <RemoveDir Directories="$(IntermediateOutputPath)BepInExStaging" />
    <ItemGroup>
      <EmbeddedResource Include="$(IntermediateOutputPath)bepinex.zip" LogicalName="Resources.bepinex.zip" />
    </ItemGroup>
  </Target>
  <!-- Zip DebugPanel output for embedding.
       Stages DLL + Info/ + Data/ from DebugPanel build output, zips to intermediate. -->
  <Target Name="ZipDebugPanel" BeforeTargets="BeforeBuild"
          Condition="Exists('../DebugPanel/bin/net35/DebugPanel.dll')"
          Inputs="../DebugPanel/bin/net35/DebugPanel.dll;../DebugPanel/bin/net35/Info/**/*;../DebugPanel/bin/net35/Data/**/*"
          Outputs="$(IntermediateOutputPath)debugpanel.zip">
    <ItemGroup>
      <DebugPanelFiles Include="../DebugPanel/bin/net35/DebugPanel.dll" />
      <DebugPanelFiles Include="../DebugPanel/bin/net35/Info/**/*" />
      <DebugPanelFiles Include="../DebugPanel/bin/net35/Data/**/*" />
    </ItemGroup>
    <RemoveDir Directories="$(IntermediateOutputPath)DebugPanelStaging" />
    <Copy SourceFiles="@(DebugPanelFiles)"
          DestinationFiles="@(DebugPanelFiles->'$(IntermediateOutputPath)DebugPanelStaging/%(RecursiveDir)%(Filename)%(Extension)')" />
    <Delete Files="$(IntermediateOutputPath)debugpanel.zip" Condition="Exists('$(IntermediateOutputPath)debugpanel.zip')" />
    <ZipDirectory SourceDirectory="$(IntermediateOutputPath)DebugPanelStaging"
                  DestinationFile="$(IntermediateOutputPath)debugpanel.zip"
                  Overwrite="true" />
    <RemoveDir Directories="$(IntermediateOutputPath)DebugPanelStaging" />
    <ItemGroup>
      <EmbeddedResource Include="$(IntermediateOutputPath)debugpanel.zip" LogicalName="Resources.debugpanel.zip" />
    </ItemGroup>
  </Target>
  <ItemGroup>
    <PackageReference Include="Avalonia" />
    <PackageReference Include="Avalonia.Desktop" />
    <PackageReference Include="Avalonia.Themes.Fluent" />
    <PackageReference Include="Avalonia.Fonts.Inter" />
    <PackageReference Include="LiveMarkdown.Avalonia" />
    <PackageReference Include="Mono.Cecil" />
  </ItemGroup>
  <ItemGroup>
    <!-- Build DebugPanel first for ZipDebugPanel target, but don't reference its output assembly -->
    <ProjectReference Include="../DebugPanel/DebugPanel.csproj" ReferenceOutputAssembly="false" />
  </ItemGroup>
  <ItemGroup>
    <EmbeddedResource Include="Resources/DemoMod.zip" LogicalName="Resources.DemoMod.zip" Condition="Exists('Resources/DemoMod.zip')" />
    <EmbeddedResource Include="Resources/docs/UsersGuide.md" LogicalName="Resources.docs.UsersGuide.md" />
    <EmbeddedResource Include="Resources/docs/ModdersGuide.md" LogicalName="Resources.docs.ModdersGuide.md" />
    <EmbeddedResource Include="Resources/docs/DebugPanel.md" LogicalName="Resources.docs.DebugPanel.md" />
    <EmbeddedResource Include="../RetargetHarmony/lib/0Harmony109.dll" LogicalName="Resources.0Harmony109.dll" />
    <EmbeddedResource Include="../RetargetHarmony/lib/0Harmony12.dll" LogicalName="Resources.0Harmony12.dll" />
    <EmbeddedResource Include="../RetargetHarmony/bin/net35/RetargetHarmony.dll" LogicalName="Resources.RetargetHarmony.dll" />
  </ItemGroup>
</Project>
