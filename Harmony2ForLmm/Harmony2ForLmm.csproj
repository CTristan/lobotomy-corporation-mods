<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <OutputType>WinExe</OutputType>
    <Nullable>enable</Nullable>
    <ProjectGuid>{E5F6A7B8-1C2D-3E4F-5A6B-7C8D9E0F1A2B}</ProjectGuid>
    <!-- IL2026: COM interop trim warning from runtime; IL2104: Mono.Cecil trim warnings (third-party) -->
    <NoWarn>$(NoWarn);IL2026;IL2104</NoWarn>
    <BuiltInComInteropSupport>true</BuiltInComInteropSupport>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <DefaultItemExcludes>$(DefaultItemExcludes);DemoMod\**</DefaultItemExcludes>
  </PropertyGroup>
  <!-- Zip DemoMod source for distribution (excludes build artifacts).
       ZipDirectory doesn't support excludes, so we copy source files to a staging
       directory first and zip that. -->
  <Target Name="ZipDemoMod" BeforeTargets="Build"
          Inputs="DemoMod\**\*.cs;DemoMod\**\*.csproj;DemoMod\**\*.md"
          Outputs="Resources\DemoMod.zip">
    <ItemGroup>
      <DemoModFiles Include="DemoMod\**\*"
                    Exclude="DemoMod\**\obj\**;DemoMod\**\bin\**;DemoMod\**\.DS_Store" />
    </ItemGroup>
    <RemoveDir Directories="$(IntermediateOutputPath)DemoModStaging" />
    <Copy SourceFiles="@(DemoModFiles)"
          DestinationFiles="@(DemoModFiles->'$(IntermediateOutputPath)DemoModStaging\DemoMod\%(RecursiveDir)%(Filename)%(Extension)')" />
    <MakeDir Directories="Resources" Condition="!Exists('Resources')" />
    <Delete Files="Resources\DemoMod.zip" Condition="Exists('Resources\DemoMod.zip')" />
    <ZipDirectory SourceDirectory="$(IntermediateOutputPath)DemoModStaging"
                  DestinationFile="Resources\DemoMod.zip"
                  Overwrite="true" />
    <RemoveDir Directories="$(IntermediateOutputPath)DemoModStaging" />
  </Target>
  <ItemGroup>
    <PackageReference Include="Avalonia" />
    <PackageReference Include="Avalonia.Desktop" />
    <PackageReference Include="Avalonia.Themes.Fluent" />
    <PackageReference Include="Avalonia.Fonts.Inter" />
    <PackageReference Include="LiveMarkdown.Avalonia" />
    <PackageReference Include="Mono.Cecil" />
  </ItemGroup>
  <ItemGroup>
    <!-- Exclude junk from BepInEx resources before the copy glob picks them up -->
    <None Remove="Resources\bepinex\**\.DS_Store" />
    <None Remove="Resources\bepinex\**\*.md" />
    <None Remove="Resources\bepinex\**\changelog*" />
    <Content Include="Resources\bepinex\**\*" Exclude="Resources\bepinex\**\.DS_Store;Resources\bepinex\**\*.md;Resources\bepinex\**\changelog*;Resources\bepinex\**\.gitignore">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>
  <ItemGroup>
    <!-- TODO: Add "Extract Sample Project" button to installer UI that extracts DemoMod.zip -->
    <Content Include="Resources\DemoMod.zip" Condition="Exists('Resources\DemoMod.zip')">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>
  <ItemGroup>
    <Content Include="Resources\docs\*.md">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>
  <ItemGroup>
    <Content Include="..\RetargetHarmony\lib\0Harmony109.dll" Link="Resources\0Harmony109.dll">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="..\RetargetHarmony\lib\0Harmony12.dll" Link="Resources\0Harmony12.dll">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="..\RetargetHarmony\bin\net35\RetargetHarmony.dll" Link="Resources\RetargetHarmony.dll">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>
</Project>
